# AI-LMS-2 Backend Environment Variables
# This is the isolated second instance. Copy to .env and fill in values.

# ─── Database (isolated from AI_LMS_1) ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://ai_lms_2:ai_lms_2_password@localhost:5433/ai_lms_db_2

# ─── JWT (different secret from AI_LMS_1) ─────────────────────────────────────
JWT_SECRET=ai_lms_2_isolated_9kXpN7mQ4rT1sW8vZ3bY6cJ0eH2fL5d
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=3600

# ─── CORS (AI_LMS_2 frontend runs on port 3001) ───────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ─── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
AI_API_KEY=gsk_your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1

# ─── Redis / Celery (isolated on port 6380) ───────────────────────────────────
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
